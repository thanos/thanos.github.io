---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
const latest = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 10);
---

<BaseLayout
  title="Thanos Vassilakis"
  description="Writing on software, systems, and notes from the field."
>
  <div class="mx-auto max-w-3xl px-4 py-12 md:py-16">
    <header class="mb-12">
      <h1 class="text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl">
        Latest articles
      </h1>
      <p class="mt-3 max-w-2xl text-neutral-600">
        ideas, tests, and Code fragments... 
        
        Browse{' '}
        <a href={`${import.meta.env.BASE_URL}articles/`} class="font-medium text-neutral-900 underline underline-offset-4"
          >all articles</a
        >
        ,{' '}
        <a href={`${import.meta.env.BASE_URL}series/`} class="font-medium text-neutral-900 underline underline-offset-4"
          >series</a
        >
        , or{' '}
        <a href={`${import.meta.env.BASE_URL}notes/`} class="font-medium text-neutral-900 underline underline-offset-4"
          >notes</a
        >.
      </p>
    </header>

    <ul class="flex flex-col gap-4">
      {
        latest.map((post) => (
          <li>
            <ArticleCard
              href={`${import.meta.env.BASE_URL}articles/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
            />
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
