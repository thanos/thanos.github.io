---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('series', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Series · Thanos Vassilakis"
  description="Series and multi-part work."
  canonicalPath="/series/"
>
  <div class="mx-auto max-w-3xl px-4 py-12 md:py-16">
    <header class="mb-10">
      <a href="/" class="text-sm text-neutral-600 underline-offset-4 hover:text-neutral-900 hover:underline">
        ← Home
      </a>
      <h1 class="mt-6 text-3xl font-semibold tracking-tight text-neutral-950">Series</h1>
    </header>
    <ul class="flex flex-col gap-4">
      {
        sorted.map((entry) => (
          <li>
            <ArticleCard
              href={`/series/${entry.id}/`}
              title={entry.data.title}
              description={entry.data.description}
              date={entry.data.date}
            />
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
