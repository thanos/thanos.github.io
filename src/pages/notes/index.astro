---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const notes = await getCollection('notes', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
const sorted = notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Notes · Thanos Vassilakis"
  description="Short notes and fragments."
  canonicalPath="/notes/"
>
  <div class="mx-auto max-w-3xl px-4 py-12 md:py-16">
    <header class="mb-10">
      <a href="/" class="text-sm text-neutral-600 underline-offset-4 hover:text-neutral-900 hover:underline">
        ← Home
      </a>
      <h1 class="mt-6 text-3xl font-semibold tracking-tight text-neutral-950">Notes</h1>
    </header>
    <ul class="flex flex-col gap-4">
      {
        sorted.map((note) => (
          <li>
            <ArticleCard
              href={`/notes/${note.id}/`}
              title={note.data.title}
              description={note.data.description}
              date={note.data.date}
            />
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
