---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
}

const { href, title, description, date } = Astro.props;
const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);
---

<a
  href={href}
  class="block rounded-lg border border-neutral-200 p-5 transition-colors hover:border-neutral-400 hover:bg-neutral-50"
>
  <h2 class="text-lg font-semibold text-neutral-950">{title}</h2>
  <p class="mt-1 text-sm text-neutral-500">{formatted}</p>
  <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{description}</p>
</a>
