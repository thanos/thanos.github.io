---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;

const base = import.meta.env.BASE_URL;
const rawPath = canonicalPath ?? Astro.url.pathname;
const pathname = rawPath.startsWith(base) ? rawPath : `${base}${rawPath.replace(/^\//, '')}`;
const canonical = new URL(pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white font-sans text-neutral-900 antialiased">
    <slot />
  </body>
</html>
